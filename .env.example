# Frontend env. In dev you can leave this unset — Vite proxies /api to
# the local backend (localhost:5000). In production (Vercel) set it to your
# deployed backend, e.g. https://manokamana-api.onrender.com/api
VITE_API_URL=

# Contact form — Web3Forms access key (https://web3forms.com).
# Enter your email there, they email you a key, paste it here.
VITE_WEB3FORMS_KEY=
