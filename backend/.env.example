# Copy this file to `.env` and fill in your values. Never commit `.env`.

# Server
PORT=5000
# Comma-separated list of allowed frontend origins (dev + production)
CORS_ORIGINS=http://localhost:5173,https://your-site.vercel.app

# Admin login — the password you will type on /admin
ADMIN_PASSWORD=change-me
# Any long random string; signs the admin session tokens
JWT_SECRET=change-me-to-a-long-random-string

# Cloudinary (Dashboard → Settings → API Keys)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
